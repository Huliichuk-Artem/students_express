
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Редагування автомобіля</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; max-width: 800px; margin: auto; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
        .form-group input { width: 100%; padding: 8px; box-sizing: border-box; }
        .btn { padding: 8px 12px; cursor: pointer; border: none; border-radius: 4px; color: #1a1d23
        .btn-submit { background-color: #ffc107; color: black; font-size: 16px; width: 100%; margin-top: 10px; font-weight: bold;}
        .btn-back { background-color: #6c757d; text-decoration: none; display: inline-block; margin-bottom: 20px; }
        .btn-back:hover { background-color: #5a6268; }
    </style>
</head>
<body>

    <a href="/cars" class="btn btn-back">⬅ Скасувати і повернутися</a>

    <h2>Редагування автомобіля: {{car.car_brand}} {{car.car_model}}</h2>
    
    <form action="/cars/edit/{{car.id}}" method="POST" style="background: #1a1d23 padding: 20px; border-radius: 8px;">
        
        <div class="form-group">
            <label for="car_brand">Марка авто:</label>
            <input type="text" id="car_brand" name="car_brand" value="{{car.car_brand}}" required>
        </div>

        <div class="form-group">
            <label for="car_model">Модель:</label>
            <input type="text" id="car_model" name="car_model" value="{{car.car_model}}" required>
        </div>

        <div class="form-group">
            <label for="engine_type">Тип двигуна:</label>
            <input type="text" id="engine_type" name="engine_type" value="{{car.engine_type}}" required>
        </div>

        <div class="form-group">
            <label for="horsepower">Кінські сили:</label>
            <input type="number" id="horsepower" name="horsepower" value="{{car.horsepower}}" required>
        </div>

        <div class="form-group">
            <label for="weight">Вага, кг:</label>
            <input type="number" id="weight" name="weight" value="{{car.weight}}" required>
        </div>

        <div class="form-group">
            <label for="acceleration_0_to_100">Розгін 0-100 км/год (с):</label>
            <input type="number" step="0.1" id="acceleration_0_to_100" name="acceleration_0_to_100" value="{{car.acceleration_0_to_100}}" required>
        </div>

        <div class="form-group">
            <label for="price">Ціна, $:</label>
            <input type="number" id="price" name="price" value="{{car.price}}" required>
        </div>

        <button type="submit" class="btn btn-submit">Зберегти зміни</button>
    </form>

</body>
</html>
